       "\[IndentingNewLine]", 
       RowBox[{"w1Collapsed", "=", 
        RowBox[{"CollapsedMethodQ", "[", "w1", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"dCS", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"capCollapsed", "||", "stableCollapsed"}], ",", 
          RowBox[{"Missing", "[", "\"\<Collapsed\>\"", "]"}], ",", 
          RowBox[{"Mean", "[", 
           RowBox[{"cap", "-", "stable"}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"dCW", "=", 
        RowBox[{"If", "[", 
