           RowBox[{"cap", ",", "w1", ",", "nBoot", ",", "alpha"}], "]"}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"pCS", "=", 
        RowBox[{"If", "[", 
