       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Length", "[", "semi", "]"}], "==", 
            RowBox[{"Length", "[", "cap", "]"}], "==", 
            RowBox[{"Length", "[", "stable", "]"}], "==", 
            RowBox[{"Length", "[", "w1", "]"}]}], ")"}]}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"<|", 
           RowBox[{
            RowBox[{"\"\<Architecture\>\"", "->", "archName"}], ",", 
            RowBox[{
            "\"\<Error\>\"", "->", 
             "\"\<All method arrays must have equal lengths.\>\""}]}], "|>"}],
           "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"semiCollapsed", "=", 
        RowBox[{"CollapsedMethodQ", "[", "semi", "]"}]}], ";", 
