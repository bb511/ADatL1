Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"::", "Section", "::"}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{
   "Spearman", " ", "correlation", " ", "extraction", " ", "from", " ", 
    "exported", " ", "MLflow", " ", "CSVs"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{
     "RunMethodFromName", ",", "MetricFilePatternForMethod", ",", 
      "EffMedFile", ",", "MetricFileForRun", ",", "LoadMetricCSV", ",", 
      "MergeOnStep", ",", "SpearmanFromCSVs", ",", "ComputeRunCorrelation", 
      ",", "ComputeExperimentCorrelations", ",", "ComputeAllCorrelations", 
      ",", "FlipSignQ"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ClearAll", "[", "ZeroVarianceQ", "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ZeroVarianceQ", "[", "x_List", "]"}], ":=", 
     RowBox[{
      RowBox[{"Length", "[", 
       RowBox[{"DeleteDuplicates", "[", 
        RowBox[{"N", "[", "x", "]"}], "]"}], "]"}], "<=", "1"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Infer", " ", "validation", " ", "method", " ", "from", " ", "run", " ", 
     "folder", " ", "name"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"RunMethodFromName", "[", "runName_String", "]"}], ":=", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{"StringStartsQ", "[", 
        RowBox[{"runName", ",", "\"\<cap\>\""}], "]"}], ",", "\"\<CAP\>\"", 
       ",", 
       RowBox[{"StringStartsQ", "[", 
        RowBox[{"runName", ",", "\"\<stability\>\""}], "]"}], ",", 
       "\"\<Stable\>\"", ",", 
       RowBox[{"StringStartsQ", "[", 
        RowBox[{"runName", ",", "\"\<wasserstein\>\""}], "]"}], ",", 
       "\"\<W1\>\"", ",", 
       RowBox[{"StringStartsQ", "[", 
        RowBox[{"runName", ",", "\"\<cvar25\>\""}], "]"}], ",", 
       "\"\<Semi\>\"", ",", "True", ",", "\"\<Unknown\>\""}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Which", " ", "metric", " ", "file", " ", "should", " ", "be", " ", 
     "used", " ", "for", " ", "each", " ", "method"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"MetricFilePatternForMethod", "[", "method_String", "]"}], ":=", 
     
     RowBox[{"Switch", "[", 
      RowBox[{"method", ",", "\"\<CAP\>\"", ",", 
       RowBox[{"{", "\"\<val_summary_cap_ema*.csv\>\"", "}"}], ",", 
       "\"\<Stable\>\"", ",", 
       RowBox[{"{", 
        RowBox[{
        "\"\<val_summary_*drift_ema*.csv\>\"", ",", 
         "\"\<val_summary_operational_drift_ema.csv\>\""}], "}"}], ",", 
       "\"\<W1\>\"", ",", 
       RowBox[{"{", "\"\<val_summary_w1dist_ema*.csv\>\"", "}"}], ",", 
       "\"\<Semi\>\"", ",", 
       RowBox[{"{", 
        RowBox[{
        "\"\<val_summary_eff_cvar25_ema*.csv\>\"", ",", 
         "\"\<val_summary_eff_cvar25_ema_operational.csv\>\""}], "}"}], ",", 
       "_", ",", "None"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Find", " ", "the", " ", "median", " ", "efficiency", " ", "CSV"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"EffMedFile", "[", "runDir_String", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "files", "}"}], ",", 
       RowBox[{
        RowBox[{"files", "=", 
         RowBox[{"FileNames", "[", 
          RowBox[{"\"\<val_summary_eff_med*.csv\>\"", ",", "runDir"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"files", "=", 
         RowBox[{"SortBy", "[", 
          RowBox[{"files", ",", "StringLength"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"files", "===", 
           RowBox[{"{", "}"}]}], ",", 
          RowBox[{"Missing", "[", "\"\<NoEffMed\>\"", "]"}], ",", 
          RowBox[{"First", "[", "files", "]"}]}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Find", " ", "the", " ", "main", " ", "metric", " ", "CSV", " ", "for", 
     " ", "a", " ", "run"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"MetricFileForRun", "[", 
      RowBox[{"runDir_String", ",", "method_String"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"pats", ",", "files"}], "}"}], ",", 
       RowBox[{
        RowBox[{"pats", "=", 
         RowBox[{"MetricFilePatternForMethod", "[", "method", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"pats", "===", "None"}], ",", 
          RowBox[{"Return", "[", 
           RowBox[{"Missing", "[", "\"\<UnknownMethod\>\"", "]"}], "]"}]}], 
         "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"files", "=", 
         RowBox[{"DeleteDuplicates", "@", 
          RowBox[{"Flatten", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"FileNames", "[", 
              RowBox[{"#", ",", "runDir"}], "]"}], "&"}], "/@", "pats"}], 
           "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"files", "===", 
           RowBox[{"{", "}"}]}], ",", 
          RowBox[{"Missing", "[", "\"\<NoMetricFile\>\"", "]"}], ",", 
          RowBox[{"First", "[", "files", "]"}]}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Read", " ", "a", " ", "CSV", " ", "exported", " ", "by", " ", "the", " ",
      "Python", " ", "script"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"LoadMetricCSV", "[", "file_String", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"ds", ",", "rows"}], "}"}], ",", 
       RowBox[{
        RowBox[{"ds", "=", 
         RowBox[{"Import", "[", 
          RowBox[{"file", ",", "\"\<CSV\>\""}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "ds", "]"}], "<", "2"}], ",", 
          RowBox[{"Return", "[", 
           RowBox[{"<|", "|>"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"rows", "=", 
         RowBox[{"Rest", "[", "ds", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Association", "[", 
         RowBox[{
          RowBox[{"\"\<step\>\"", "->", 
           RowBox[{"ToExpression", "[", 
            RowBox[{"rows", "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "3"}], "]"}], "]"}], "]"}]}], ",", 
          RowBox[{"\"\<value\>\"", "->", 
           RowBox[{"ToExpression", "[", 
            RowBox[{"rows", "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}]}], "]"}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Inner", " ", "join", " ", "on", " ", "step"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"MergeOnStep", "[", 
      RowBox[{"effAssoc_Association", ",", "metricAssoc_Association"}], "]"}],
      ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "effSteps", ",", "metSteps", ",", "common", ",", "effMap", ",", 
         "metMap"}], "}"}], ",", 
       RowBox[{
        RowBox[{"effSteps", "=", 
         RowBox[{"effAssoc", "[", "\"\<step\>\"", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"metSteps", "=", 
         RowBox[{"metricAssoc", "[", "\"\<step\>\"", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"common", "=", 
         RowBox[{"Intersection", "[", 
          RowBox[{"effSteps", ",", "metSteps"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"effMap", "=", 
         RowBox[{"AssociationThread", "[", 
          RowBox[{"effSteps", "->", 
           RowBox[{"effAssoc", "[", "\"\<value\>\"", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"metMap", "=", 
         RowBox[{"AssociationThread", "[", 
          RowBox[{"metSteps", "->", 
           RowBox[{"metricAssoc", "[", "\"\<value\>\"", "]"}]}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<step\>\"", "->", "common"}], ",", 
          RowBox[{"\"\<eff\>\"", "->", 
           RowBox[{"Lookup", "[", 
            RowBox[{"effMap", ",", "common"}], "]"}]}], ",", 
          RowBox[{"\"\<metric\>\"", "->", 
           RowBox[{"Lookup", "[", 
            RowBox[{"metMap", ",", "common"}], "]"}]}]}], "|>"}]}]}], "]"}]}],
     ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Whether", " ", "to", " ", "flip", " ", "sign", " ", "so", " ", 
     "\"\<better metric\>\"", " ", "means", " ", "larger", " ", "is", " ", 
     "better"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"FlipSignQ", "[", "method_String", "]"}], ":=", 
     RowBox[{"MemberQ", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\"\<Stable\>\"", ",", "\"\<W1\>\""}], "}"}], ",", "method"}],
       "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Compute", " ", "Spearman", " ", "from", " ", "two", " ", "CSV", " ", 
     "files"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SpearmanFromCSVs", "[", 
     RowBox[{
     "effFile_String", ",", "metricFile_String", ",", "method_String", ",", 
      RowBox[{"flipSign_", ":", "True"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"eff", ",", "met", ",", "merged", ",", "x", ",", "y"}], "}"}], 
      ",", 
      RowBox[{
       RowBox[{"eff", "=", 
        RowBox[{"LoadMetricCSV", "[", "effFile", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"met", "=", 
        RowBox[{"LoadMetricCSV", "[", "metricFile", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"eff", "===", 
           RowBox[{"<|", "|>"}]}], "||", 
          RowBox[{"met", "===", 
           RowBox[{"<|", "|>"}]}]}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"Missing", "[", "\"\<EmptyCSV\>\"", "]"}], "]"}]}], "]"}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"merged", "=", 
        RowBox[{"MergeOnStep", "[", 
         RowBox[{"eff", ",", "met"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"x", "=", 
        RowBox[{"merged", "[", "\"\<metric\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"y", "=", 
        RowBox[{"merged", "[", "\"\<eff\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "x", "]"}], "<", "3"}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"Missing", "[", "\"\<TooFewPoints\>\"", "]"}], "]"}]}], 
        "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"flipSign", "&&", 
          RowBox[{"FlipSignQ", "[", "method", "]"}]}], ",", 
         RowBox[{"x", "=", 
          RowBox[{"-", "x"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"ZeroVarianceQ", "[", "x", "]"}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"Missing", "[", "\"\<ZeroVarianceMetric\>\"", "]"}], 
          "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"ZeroVarianceQ", "[", "y", "]"}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"Missing", "[", "\"\<ZeroVarianceEfficiency\>\"", "]"}], 
          "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Quiet", "[", 
        RowBox[{"Check", "[", 
         RowBox[{
          RowBox[{"SpearmanRho", "[", 
           RowBox[{"x", ",", "y"}], "]"}], ",", 
          RowBox[{"Missing", "[", "\"\<SpearmanFailed\>\"", "]"}]}], "]"}], 
        "]"}]}]}], "]"}]}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Compute", " ", "one", " ", "run"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ComputeRunCorrelation", "[", 
      RowBox[{"runDir_String", ",", 
       RowBox[{"flipSign_", ":", "True"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "runName", ",", "method", ",", "effFile", ",", "metricFile", ",", 
         "rho"}], "}"}], ",", 
       RowBox[{
        RowBox[{"runName", "=", 
         RowBox[{"FileNameTake", "[", "runDir", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"method", "=", 
         RowBox[{"RunMethodFromName", "[", "runName", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"effFile", "=", 
         RowBox[{"EffMedFile", "[", "runDir", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"metricFile", "=", 
         RowBox[{"MetricFileForRun", "[", 
          RowBox[{"runDir", ",", "method"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"MissingQ", "[", "effFile", "]"}], "||", 
           RowBox[{"MissingQ", "[", "metricFile", "]"}]}], ",", 
          RowBox[{"Return", "[", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<Run\>\"", "->", "runName"}], ",", 
             RowBox[{"\"\<Method\>\"", "->", "method"}], ",", 
             RowBox[{"\"\<EffMedFile\>\"", "->", "effFile"}], ",", 
             RowBox[{"\"\<MetricFile\>\"", "->", "metricFile"}], ",", 
             RowBox[{"\"\<SpearmanRho\>\"", "->", 
              RowBox[{"Missing", "[", "\"\<Unavailable\>\"", "]"}]}]}], 
            "|>"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"rho", "=", 
         RowBox[{"SpearmanFromCSVs", "[", 
          RowBox[{
          "effFile", ",", "metricFile", ",", "method", ",", "flipSign"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<Run\>\"", "->", "runName"}], ",", 
          RowBox[{"\"\<Method\>\"", "->", "method"}], ",", 
          RowBox[{"\"\<EffMedFile\>\"", "->", "effFile"}], ",", 
          RowBox[{"\"\<MetricFile\>\"", "->", "metricFile"}], ",", 
          RowBox[{"\"\<SpearmanRho\>\"", "->", "rho"}]}], "|>"}]}]}], "]"}]}],
     ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Compute", " ", "all", " ", "runs", " ", "inside", " ", "one", " ", 
     "experiment", " ", "folder"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ComputeExperimentCorrelations", "[", 
      RowBox[{"expDir_String", ",", 
       RowBox[{"flipSign_", ":", "True"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"runDirs", ",", "results"}], "}"}], ",", 
       RowBox[{
        RowBox[{"runDirs", "=", 
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"FileNames", "[", 
            RowBox[{"\"\<*\>\"", ",", "expDir"}], "]"}], ",", "DirectoryQ"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"results", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"ComputeRunCorrelation", "[", 
            RowBox[{"#", ",", "flipSign"}], "]"}], "&"}], "/@", "runDirs"}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"AssociationThread", "[", 
         RowBox[{
          RowBox[{"FileNameTake", "/@", "runDirs"}], "->", "results"}], 
         "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Compute", " ", "all", " ", "experiment", " ", "folders", " ", "under", 
     " ", "a", " ", "root"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ComputeAllCorrelations", "[", 
      RowBox[{"rootDir_String", ",", 
       RowBox[{"flipSign_", ":", "True"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "expDirs", "}"}], ",", 
       RowBox[{
        RowBox[{"expDirs", "=", 
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"FileNames", "[", 
            RowBox[{"\"\<*\>\"", ",", "rootDir"}], "]"}], ",", "DirectoryQ"}],
           "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"AssociationThread", "[", 
         RowBox[{
          RowBox[{"FileNameTake", "/@", "expDirs"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"ComputeExperimentCorrelations", "[", 
             RowBox[{"#", ",", "flipSign"}], "]"}], "&"}], "/@", 
           "expDirs"}]}], "]"}]}]}], "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.986580360996291*^9, 3.986580372671133*^9}, {
   3.986588054007105*^9, 3.986588091260872*^9}, {3.986588184957563*^9, 
   3.986588186092977*^9}, 3.986588222245121*^9},
 CellLabel->"In[15]:=",ExpressionUUID->"cc47976f-6c37-49bb-8242-282263d0bd8e"],

