Cell[BoxData[
 RowBox[{
  RowBox[{"makeBoxCMS", "[", 
   RowBox[{
   "data_", ",", "labels_", ",", "yLabel_", ",", "cmsPos_", ",", "tevPos_", 
    ",", 
    RowBox[{"precY_", ":", "1"}], ",", 
    RowBox[{"xLabelY_", ":", "0.06"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "majorLen", ",", "minorLen", ",", "makeTicks01", ",", "yVals", ",", 
      "yTicks", ",", "yTicksRight", ",", "plot", ",", "cmsText", ",", 
      "tevText", ",", 
      RowBox[{"plotLeft", "=", "0.01"}], ",", 
      RowBox[{"plotBottom", "=", "0.12"}], ",", 
      RowBox[{"plotWidth", "=", "0.98"}], ",", 
      RowBox[{"plotHeight", "=", "0.84"}], ",", "xCenters"}], "}"}], ",", 
    RowBox[{
     RowBox[{"majorLen", "=", 
      RowBox[{"Scaled", "[", "0.015", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"minorLen", "=", 
      RowBox[{"Scaled", "[", 
       RowBox[{"0.015", "/", "2"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"makeTicks01", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"vmin_", "?", "NumericQ"}], ",", 
          RowBox[{"vmax_", "?", "NumericQ"}]}], "}"}], ",", "prec_"}], "]"}], 
      ":=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"maj", ",", "min"}], "}"}], ",", 
        RowBox[{
         RowBox[{"maj", "=", 
          RowBox[{"N", "@", 
           RowBox[{"FindDivisions", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"vmin", ",", "vmax"}], "}"}], ",", "6"}], "]"}]}]}], 
         ";", "\[IndentingNewLine]", 
         RowBox[{"min", "=", 
          RowBox[{"N", "@", 
           RowBox[{"Flatten", "@", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"Most", "@", 
               RowBox[{"Rest", "@", 
                RowBox[{"Subdivide", "[", 
                 RowBox[{
                  RowBox[{"maj", "[", 
                   RowBox[{"[", "k", "]"}], "]"}], ",", 
                  RowBox[{"maj", "[", 
                   RowBox[{"[", 
                    RowBox[{"k", "+", "1"}], "]"}], "]"}], ",", "6"}], 
                 "]"}]}]}], ",", 
              RowBox[{"{", 
               RowBox[{"k", ",", "1", ",", 
                RowBox[{
                 RowBox[{"Length", "[", "maj", "]"}], "-", "1"}]}], "}"}]}], 
             "]"}]}]}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"#", ",", 
                RowBox[{"NumberForm", "[", 
                 RowBox[{"#", ",", 
                  RowBox[{"{", 
                   RowBox[{"6", ",", "prec"}], "}"}]}], "]"}], ",", 
                RowBox[{"{", 
                 RowBox[{"majorLen", ",", "0"}], "}"}]}], "}"}], "&"}], "/@", 
             "maj"}], ")"}], ",", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"#", ",", "\"\<\>\"", ",", 
                RowBox[{"{", 
                 RowBox[{"minorLen", ",", "0"}], "}"}]}], "}"}], "&"}], "/@", 
             "min"}], ")"}]}], "]"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"yVals", "=", 
      RowBox[{"Flatten", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"yTicks", "=", 
      RowBox[{"makeTicks01", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"1.05", " ", 
           RowBox[{"Max", "[", "yVals", "]"}]}]}], "}"}], ",", "precY"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"yTicksRight", "=", 
      RowBox[{"yTicks", "/.", " ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"v_", ",", "_", ",", "len_"}], "}"}], ":>", 
        RowBox[{"{", 
         RowBox[{"v", ",", "\"\<\>\"", ",", "len"}], "}"}]}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"plot", "=", 
      RowBox[{"BoxWhiskerChart", "[", "\[IndentingNewLine]", 
       RowBox[{"data", ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"\"\<Outliers\>\"", ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"\"\<MedianMarker\>\"", ",", "1.0", ",", 
            RowBox[{"Directive", "[", 
             RowBox[{"Yellow", ",", 
              RowBox[{"AbsoluteThickness", "[", "3", "]"}]}], "]"}]}], "}"}], 
          ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"\"\<Whiskers\>\"", ",", 
            RowBox[{"Directive", "[", 
             RowBox[{"Black", ",", 
              RowBox[{"AbsoluteThickness", "[", "3", "]"}]}], "]"}]}], "}"}], 
          ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"\"\<Fences\>\"", ",", "0.5", ",", 
            RowBox[{"Directive", "[", 
             RowBox[{"Black", ",", 
              RowBox[{"AbsoluteThickness", "[", "2", "]"}]}], "]"}]}], "}"}], 
          ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"\"\<Outliers\>\"", ",", 
            RowBox[{"Directive", "[", 
             RowBox[{"Black", ",", 
              RowBox[{"AbsolutePointSize", "[", "5", "]"}]}], "]"}]}], 
           "}"}]}], "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"ChartStyle", "->", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Directive", "[", 
            RowBox[{
             RowBox[{"RGBColor", "[", "\"\<#3f90da\>\"", "]"}], ",", 
             RowBox[{"Opacity", "[", "0.85", "]"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"Length", "[", "data", "]"}], "}"}]}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Frame", "->", "True"}], ",", 
        RowBox[{"Axes", "->", "False"}], ",", "\[IndentingNewLine]", 
        RowBox[{"FrameTicks", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"yTicks", ",", "yTicksRight"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"Automatic", ",", "Automatic"}], "}"}]}], "}"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"FrameStyle", "->", 
         RowBox[{"Directive", "[", 
          RowBox[{"Black", ",", 
           RowBox[{"AbsoluteThickness", "[", "2", "]"}]}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"FrameTicksStyle", "->", 
         RowBox[{"Directive", "[", 
          RowBox[{"Black", ",", 
           RowBox[{"FontSize", "->", "22"}], ",", 
           RowBox[{"FontFamily", "->", "\"\<TeX Gyre Heros\>\""}]}], "]"}]}], 
        ",", "\[IndentingNewLine]", 
        RowBox[{"LabelStyle", "->", 
         RowBox[{"Directive", "[", 
          RowBox[{"Black", ",", 
           RowBox[{"FontSize", "->", "24"}], ",", 
           RowBox[{"FontFamily", "->", "\"\<TeX Gyre Heros\>\""}]}], "]"}]}], 
        ",", "\[IndentingNewLine]", 
        RowBox[{"FrameLabel", "->", 
         RowBox[{"{", 
          RowBox[{"None", ",", 
           RowBox[{"Style", "[", 
            RowBox[{"yLabel", ",", "Black", ",", 
             RowBox[{"FontSize", "->", "30"}], ",", 
             RowBox[{"FontFamily", "->", "\"\<TeX Gyre Heros\>\""}]}], 
            "]"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"GridLines", "->", 
         RowBox[{"{", 
          RowBox[{"None", ",", "Automatic"}], "}"}]}], ",", 
        RowBox[{"GridLinesStyle", "->", 
         RowBox[{"Directive", "[", 
          RowBox[{"GrayLevel", "[", "0.85", "]"}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"ImageSize", "->", "1300"}], ",", 
        RowBox[{"AspectRatio", "->", "0.5"}], ",", 
        RowBox[{"ImagePadding", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"100", ",", "40"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"40", ",", "40"}], "}"}]}], "}"}]}], ",", 
        RowBox[{"PlotRange", "->", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"1.05", " ", 
            RowBox[{"Max", "[", "yVals", "]"}]}]}], "}"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"PlotRangePadding", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Scaled", "[", 
              RowBox[{"-", "0.1"}], "]"}], ",", 
             RowBox[{"Scaled", "[", "0.02", "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Scaled", "[", "0.05", "]"}], ",", 
             RowBox[{"Scaled", "[", "0.01", "]"}]}], "}"}]}], "}"}]}]}], 
       "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"cmsText", "=", 
      RowBox[{"Row", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Style", "[", 
          RowBox[{"\"\<CMS\>\"", ",", "Bold", ",", 
           RowBox[{"FontFamily", "->", "\"\<TeX Gyre Heros\>\""}], ",", 
           "24"}], "]"}], ",", 
         RowBox[{"Style", "[", 
          RowBox[{"\"\< Simulation Preliminary\>\"", ",", "Italic", ",", 
           RowBox[{"FontFamily", "->", "\"\<TeX Gyre Heros\>\""}], ",", 
           "24"}], "]"}]}], "}"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"tevText", "=", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<14 TeV\>\"", ",", 
        RowBox[{"FontFamily", "->", "\"\<TeX Gyre Heros\>\""}], ",", "24"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"xCenters", "=", 
      RowBox[{"{", 
       RowBox[{"0.19", ",", " ", "0.36", ",", "0.535", ",", " ", "0.71"}], 
       "}"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Graphics", "[", 
