Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{
     "BootstrapPairedDiffCI", ",", "WilcoxonSignedRankPExact", ",", 
      "SafeWilcoxonP", ",", "CollapsedMethodQ", ",", "FormatNum", ",", 
      "FormatP", ",", "FormatMeanOrDash", ",", "FormatAsymPMOrDash", ",", 
      "ArchitectureRowDataCompactCollapse", ",", 
      "LatexRowCompactAsymCollapse", ",", 
      "BuildArchitectureRowsCompactCollapse", ",", 
      "BuildLatexTableCompactAsymCollapse"}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Treat", " ", "all"}], "-", 
     RowBox[{"zero", " ", "arrays", " ", "as", " ", "collapsed"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"CollapsedMethodQ", "[", "x_List", "]"}], ":=", 
     RowBox[{"AllTrue", "[", 
      RowBox[{"x", ",", 
       RowBox[{
        RowBox[{"#", "==", "0."}], "&"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "95", "%", " ", "bootstrap", " ", "CI", " ", "for", " ", "paired", " ", 
     "mean", " ", 
     RowBox[{"difference", ":", 
      RowBox[{"a", "-", "b"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"BootstrapPairedDiffCI", "[", 
      RowBox[{"a_List", ",", "b_List", ",", 
       RowBox[{"nBoot_", ":", "10000"}], ",", 
       RowBox[{"alpha_", ":", "0.05"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"n", ",", "diffs", ",", "boots"}], "}"}], ",", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "a", "]"}], "=!=", 
           RowBox[{"Length", "[", "b", "]"}]}], ",", 
          RowBox[{"Return", "[", 
           RowBox[{"Missing", "[", "\"\<LengthMismatch\>\"", "]"}], "]"}]}], 
         "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"n", "=", 
         RowBox[{"Length", "[", "a", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"diffs", "=", 
         RowBox[{"a", "-", "b"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"boots", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Mean", "[", 
            RowBox[{"RandomChoice", "[", 
             RowBox[{"diffs", ",", "n"}], "]"}], "]"}], ",", 
           RowBox[{"{", "nBoot", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Quantile", "[", 
         RowBox[{"boots", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"alpha", "/", "2"}], ",", 
            RowBox[{"1", "-", 
             RowBox[{"alpha", "/", "2"}]}]}], "}"}]}], "]"}]}]}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Exact", " ", "two"}], "-", 
     RowBox[{"sided", " ", "Wilcoxon", " ", "signed"}], "-", 
     RowBox[{"rank", " ", "p"}], "-", "value"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"WilcoxonSignedRankPExact", "[", 
      RowBox[{"a_List", ",", "b_List"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "d", ",", "absd", ",", "sgn", ",", "n", ",", "order", ",", 
         "sortedAbs", ",", "sortedIdx", ",", "ranks", ",", "groups", ",", 
         "start", ",", "wPlus", ",", "allSums", ",", "pLeft", ",", "pRight"}],
         "}"}], ",", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "a", "]"}], "=!=", 
           RowBox[{"Length", "[", "b", "]"}]}], ",", 
          RowBox[{"Return", "[", 
           RowBox[{"Missing", "[", "\"\<LengthMismatch\>\"", "]"}], "]"}]}], 
         "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"d", "=", 
         RowBox[{"DeleteCases", "[", 
          RowBox[{
           RowBox[{"a", "-", "b"}], ",", "0."}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"d", "===", 
           RowBox[{"{", "}"}]}], ",", 
          RowBox[{"Return", "[", "1.0", "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"absd", "=", 
         RowBox[{"Abs", "[", "d", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"sgn", "=", 
         RowBox[{"Sign", "[", "d", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"n", "=", 
         RowBox[{"Length", "[", "d", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"order", "=", 
         RowBox[{"Ordering", "[", "absd", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"sortedAbs", "=", 
         RowBox[{"absd", "[", 
          RowBox[{"[", "order", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"sortedIdx", "=", "order"}], ";", "\[IndentingNewLine]", 
        RowBox[{"ranks", "=", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{"0.", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"groups", "=", 
         RowBox[{"Split", "[", 
          RowBox[{
           RowBox[{"Range", "[", "n", "]"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"sortedAbs", "[", 
              RowBox[{"[", "#1", "]"}], "]"}], "==", 
             RowBox[{"sortedAbs", "[", 
              RowBox[{"[", "#2", "]"}], "]"}]}], "&"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"start", "=", "1"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"len", "=", 
               RowBox[{"Length", "[", "g", "]"}]}], ",", "mid"}], "}"}], ",", 
            
            RowBox[{
             RowBox[{"mid", "=", 
              RowBox[{"Mean", "[", 
               RowBox[{"Range", "[", 
                RowBox[{"start", ",", 
                 RowBox[{"start", "+", "len", "-", "1"}]}], "]"}], "]"}]}], 
             ";", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"ranks", "[", 
               RowBox[{"[", 
                RowBox[{"sortedIdx", "[", 
                 RowBox[{"[", "g", "]"}], "]"}], "]"}], "]"}], "=", "mid"}], 
             ";", "\[IndentingNewLine]", 
             RowBox[{"start", "+=", "len"}], ";"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"g", ",", "groups"}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"wPlus", "=", 
         RowBox[{"Total", "[", 
          RowBox[{"Pick", "[", 
           RowBox[{"ranks", ",", "sgn", ",", "1"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"allSums", "=", 
         RowBox[{"Total", "/@", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"Pick", "[", 
              RowBox[{"ranks", ",", "#", ",", "1"}], "]"}], "&"}], "/@", 
            RowBox[{"Tuples", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"0", ",", "1"}], "}"}], ",", "n"}], "]"}]}], ")"}]}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"pLeft", "=", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"Count", "[", 
            RowBox[{"allSums", ",", 
             RowBox[{"x_", "/;", 
              RowBox[{"x", "<=", "wPlus"}]}]}], "]"}], "/", 
           RowBox[{"Length", "[", "allSums", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"pRight", "=", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"Count", "[", 
            RowBox[{"allSums", ",", 
             RowBox[{"x_", "/;", 
              RowBox[{"x", ">=", "wPlus"}]}]}], "]"}], "/", 
           RowBox[{"Length", "[", "allSums", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Min", "[", 
         RowBox[{"1.0", ",", 
          RowBox[{"2.0", " ", 
           RowBox[{"Min", "[", 
            RowBox[{"pLeft", ",", "pRight"}], "]"}]}]}], "]"}]}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"SafeWilcoxonP", "[", 
      RowBox[{"a_List", ",", "b_List"}], "]"}], ":=", 
     RowBox[{"WilcoxonSignedRankPExact", "[", 
      RowBox[{"a", ",", "b"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"FormatNum", "[", 
      RowBox[{"x_", ",", 
       RowBox[{"digits_", ":", "2"}]}], "]"}], ":=", 
     RowBox[{"ToString", "@", 
      RowBox[{"NumberForm", "[", 
       RowBox[{"x", ",", 
        RowBox[{"{", 
         RowBox[{"Infinity", ",", "digits"}], "}"}], ",", 
        RowBox[{"NumberPadding", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<\>\"", ",", "\"\<0\>\""}], "}"}]}], ",", 
        RowBox[{"NumberPoint", "->", "\"\<.\>\""}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"FormatP", "[", "p_", "]"}], ":=", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{"MissingQ", "[", "p", "]"}], ",", "\"\<-\>\"", ",", 
       RowBox[{"p", "<", "0.001"}], ",", "\"\<<0.001\>\"", ",", "True", ",", 
       RowBox[{"ToString", "@", 
        RowBox[{"NumberForm", "[", 
         RowBox[{"p", ",", 
          RowBox[{"{", 
           RowBox[{"Infinity", ",", "3"}], "}"}], ",", 
          RowBox[{"NumberPadding", "->", 
           RowBox[{"{", 
            RowBox[{"\"\<\>\"", ",", "\"\<0\>\""}], "}"}]}], ",", 
          RowBox[{"NumberPoint", "->", "\"\<.\>\""}]}], "]"}]}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"FormatMeanOrDash", "[", 
      RowBox[{"x_List", ",", 
       RowBox[{"digits_", ":", "2"}]}], "]"}], ":=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"CollapsedMethodQ", "[", "x", "]"}], ",", "\"\<-\>\"", ",", 
       RowBox[{"FormatNum", "[", 
        RowBox[{
         RowBox[{"Mean", "[", "x", "]"}], ",", "digits"}], "]"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"FormatAsymPMOrDash", "[", 
      RowBox[{"center_", ",", "ci_List", ",", 
       RowBox[{"digits_", ":", "2"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"lower", ",", "upper"}], "}"}], ",", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"MissingQ", "[", "center", "]"}], "||", 
           RowBox[{"MissingQ", "[", "ci", "]"}]}], ",", 
          RowBox[{"Return", "[", "\"\<-\>\"", "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"lower", "=", 
         RowBox[{"center", "-", 
          RowBox[{"ci", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"upper", "=", 
         RowBox[{
          RowBox[{"ci", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "-", "center"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"\"\<$\>\"", "<>", 
         RowBox[{"FormatNum", "[", 
          RowBox[{"center", ",", "digits"}], "]"}], "<>", "\"\<^{+\>\"", "<>", 
         RowBox[{"FormatNum", "[", 
          RowBox[{"upper", ",", "digits"}], "]"}], "<>", "\"\<}\>\"", "<>", 
         "\"\<_{-\>\"", "<>", 
         RowBox[{"FormatNum", "[", 
          RowBox[{"lower", ",", "digits"}], "]"}], "<>", "\"\<}$\>\""}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"ArchitectureRowDataCompactCollapse", "[", 
      RowBox[{"archName_String", ",", "methods_Association", ",", 
       RowBox[{"nBoot_", ":", "10000"}], ",", 
       RowBox[{"alpha_", ":", "0.05"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "semi", ",", "cap", ",", "stable", ",", "w1", ",", "semiCollapsed", 
         ",", "capCollapsed", ",", "stableCollapsed", ",", "w1Collapsed", ",",
          "dCS", ",", "dCW", ",", "ciCS", ",", "ciCW", ",", "pCS", ",", 
         "pCW"}], "}"}], ",", 
       RowBox[{
        RowBox[{"semi", "=", 
         RowBox[{"methods", "[", "\"\<semisupervised\>\"", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"cap", "=", 
         RowBox[{"methods", "[", "\"\<CAP\>\"", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"stable", "=", 
