 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"BuildArchitectureRowsCompactCollapse", "[", 
     RowBox[{"allArchitectures_Association", ",", 
      RowBox[{"nBoot_", ":", "10000"}], ",", 
      RowBox[{"alpha_", ":", "0.05"}]}], "]"}], ":=", 
    RowBox[{"KeyValueMap", "[", 
     RowBox[{
