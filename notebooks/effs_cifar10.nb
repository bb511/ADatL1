         RowBox[{"\"\<CAPMinusW1CI\>\"", "->", "ciCW"}], ",", 
         RowBox[{"\"\<CAPMinusW1P\>\"", "->", "pCW"}]}], "|>"}]}]}], "]"}]}], 
