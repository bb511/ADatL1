           RowBox[{"row", "[", "\"\<Semi\>\"", "]"}], ",", "digits"}], "]"}], 
         ",", 
         RowBox[{"FormatMeanOrDash", "[", 
          RowBox[{
           RowBox[{"row", "[", "\"\<CAP\>\"", "]"}], ",", "digits"}], "]"}], 
         ",", 
         RowBox[{"FormatMeanOrDash", "[", 
          RowBox[{
           RowBox[{"row", "[", "\"\<Stable\>\"", "]"}], ",", "digits"}], 
          "]"}], ",", 
