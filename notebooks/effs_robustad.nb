          RowBox[{
           RowBox[{"row", "[", "\"\<W1\>\"", "]"}], ",", "digits"}], "]"}], 
         ",", 
         RowBox[{"FormatAsymPMOrDash", "[", 
          RowBox[{
           RowBox[{"row", "[", "\"\<CAPMinusStable\>\"", "]"}], ",", 
           RowBox[{"row", "[", "\"\<CAPMinusStableCI\>\"", "]"}], ",", 
           "digits"}], "]"}], ",", 
         RowBox[{"FormatP", "[", 
          RowBox[{"row", "[", "\"\<CAPMinusStableP\>\"", "]"}], "]"}], ",", 
         RowBox[{"FormatAsymPMOrDash", "[", 
          RowBox[{
           RowBox[{"row", "[", "\"\<CAPMinusW1\>\"", "]"}], ",", 
           RowBox[{"row", "[", "\"\<CAPMinusW1CI\>\"", "]"}], ",", "digits"}],
           "]"}], ",", 
         RowBox[{"FormatP", "[", 
          RowBox[{"row", "[", "\"\<CAPMinusW1P\>\"", "]"}], "]"}]}], "}"}], 
       ",", "\"\< & \>\""}], "]"}], "<>", "\"\< \\\\\\\\\>\""}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"BuildArchitectureRowsCompactCollapse", "[", 
     RowBox[{"allArchitectures_Association", ",", 
      RowBox[{"nBoot_", ":", "10000"}], ",", 
      RowBox[{"alpha_", ":", "0.05"}]}], "]"}], ":=", 
    RowBox[{"KeyValueMap", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"ArchitectureRowDataCompactCollapse", "[", 
