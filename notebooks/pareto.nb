         "\[IndentingNewLine]", 
        RowBox[{"min", "=", 
         RowBox[{"N", "@", 
          RowBox[{"Flatten", "@", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"Most", "@", 
              RowBox[{"Rest", "@", 
               RowBox[{"Subdivide", "[", 
