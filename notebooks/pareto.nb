Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SetDirectory", "[", 
    RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"user", "-", 
    RowBox[{"chosen", " ", "trials"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"dataName", " ", "=", " ", 
  "\"\<rmse_b16k\>\""}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"userHighlight", "=", 
    RowBox[{"{", 
     RowBox[{"260", ",", " ", "204"}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", "optional", "*)"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"Import", "[", 
    RowBox[{
    "\"\<paretos/\>\"", " ", "<>", "dataName", " ", "<>", " ", 
     "\"\<.csv\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"headers", "=", 
   RowBox[{"First", "[", "data", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rows", "=", 
    RowBox[{"Rest", "[", "data", "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"col", "[", "name_String", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"pos", "=", 
        RowBox[{"FirstPosition", "[", 
         RowBox[{"headers", ",", "name"}], "]"}]}], "}"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"pos", "===", 
         RowBox[{"Missing", "[", "\"\<NotFound\>\"", "]"}]}], ",", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{"\"\<Column not found: \>\"", ",", "name"}], "]"}], ";", 
         RowBox[{"Abort", "[", "]"}]}], ",", 
        RowBox[{"First", "[", "pos", "]"}]}], "]"}]}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"safe", " ", "string"}], "->", "number"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"toNum", "[", 
    RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{"N", "@", "x"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"toNum", "[", "s_String", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"t", "=", 
       RowBox[{"StringTrim", "[", "s", "]"}]}], "}"}], ",", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"t", "==", "\"\<\>\""}], "||", 
        RowBox[{
         RowBox[{"ToLowerCase", "[", "t", "]"}], "==", "\"\<nan\>\""}], "||", 
        
        RowBox[{
         RowBox[{"ToLowerCase", "[", "t", "]"}], "==", "\"\<none\>\""}], "||", 
        RowBox[{
         RowBox[{"ToLowerCase", "[", "t", "]"}], "==", "\"\<null\>\""}]}], 
       ",", 
       RowBox[{"Missing", "[", "\"\<NotANumber\>\"", "]"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"ToLowerCase", "[", "t", "]"}], "==", "\"\<inf\>\""}], "||", 
        
        RowBox[{
         RowBox[{"ToLowerCase", "[", "t", "]"}], "==", "\"\<+inf\>\""}], "||", 
        RowBox[{
         RowBox[{"ToLowerCase", "[", "t", "]"}], "==", "\"\<infinity\>\""}]}],
        ",", "Infinity", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"ToLowerCase", "[", "t", "]"}], "==", "\"\<-inf\>\""}], "||", 
        RowBox[{
         RowBox[{"ToLowerCase", "[", "t", "]"}], "==", 
         "\"\<-infinity\>\""}]}], ",", 
       RowBox[{"-", "Infinity"}], ",", "True", ",", 
       RowBox[{"Quiet", "@", 
        RowBox[{"Check", "[", 
         RowBox[{
          RowBox[{"N", "@", 
           RowBox[{"ToExpression", "[", "t", "]"}]}], ",", 
          RowBox[{"Missing", "[", "\"\<NotANumber\>\"", "]"}]}], "]"}]}]}], 
      "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"toNum", "[", "_", "]"}], ":=", 
    RowBox[{"Missing", "[", "\"\<NotANumber\>\"", "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"isFiniteReal", "[", "x_", "]"}], ":=", 
    RowBox[{
     RowBox[{"NumericQ", "[", "x", "]"}], "&&", 
     RowBox[{"x", "=!=", "Indeterminate"}], "&&", 
     RowBox[{"x", "=!=", "ComplexInfinity"}], "&&", 
     RowBox[{"x", "=!=", "Infinity"}], "&&", 
     RowBox[{"x", "=!=", 
      RowBox[{"-", "Infinity"}]}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"filter", " ", "COMPLETE"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"completeRows", "=", 
    RowBox[{"Select", "[", 
     RowBox[{"rows", ",", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", 
          RowBox[{"col", "[", "\"\<state\>\"", "]"}], "]"}], "]"}], "==", 
        "\"\<COMPLETE\>\""}], "&"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"trialNumsAll", "=", 
   RowBox[{
    RowBox[{"completeRows", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", 
       RowBox[{"col", "[", "\"\<number\>\"", "]"}]}], "]"}], "]"}], "/.", " ", 
    RowBox[{"s_String", ":>", 
     RowBox[{"Quiet", "@", 
      RowBox[{"Check", "[", 
       RowBox[{
        RowBox[{"ToExpression", "[", 
         RowBox[{"StringTrim", "[", "s", "]"}], "]"}], ",", 
        RowBox[{"Missing", "[", "\"\<NotANumber\>\"", "]"}]}], "]"}]}]}]}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"valsAll", "=", 
    RowBox[{"toNum", "/@", 
     RowBox[{"completeRows", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", 
        RowBox[{"col", "[", "\"\<values_0\>\"", "]"}]}], "]"}], "]"}]}]}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"goodMask", "=", 
    RowBox[{"MapThread", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"isFiniteReal", "[", "#1", "]"}], "&&", 
         RowBox[{"isFiniteReal", "[", "#2", "]"}]}], ")"}], "&"}], ",", 
      RowBox[{"{", 
       RowBox[{"trialNumsAll", ",", "valsAll"}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"trialNums", "=", 
   RowBox[{"Pick", "[", 
    RowBox[{"trialNumsAll", ",", "goodMask"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"vals", "=", 
    RowBox[{"Pick", "[", 
     RowBox[{"valsAll", ",", "goodMask"}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pts", "=", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"trialNums", ",", "vals"}], "}"}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"user", " ", "highlighting"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"isUser", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"MemberQ", "[", 
      RowBox[{"userHighlight", ",", "#"}], "]"}], "&"}], "/@", 
    "trialNums"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"userPts", "=", 
   RowBox[{"Pick", "[", 
    RowBox[{"pts", ",", "isUser", ",", "True"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"otherPts", "=", 
   RowBox[{"Pick", "[", 
    RowBox[{"pts", ",", "isUser", ",", "False"}], "]"}]}], ";"}]}], "Input",
