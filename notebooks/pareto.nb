   RowBox[{
    RowBox[{
     RowBox[{"makeTicksX", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"vmin_", "?", "NumericQ"}], ",", 
        RowBox[{"vmax_", "?", "NumericQ"}]}], "}"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
