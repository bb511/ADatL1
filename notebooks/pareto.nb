  RowBox[{
   RowBox[{
    RowBox[{"majorLen", "=", 
     RowBox[{"Scaled", "[", "0.015", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"minorLen", "=", 
     RowBox[{"Scaled", "[", 
      RowBox[{"0.015", "/", "2"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"X", " ", 
     RowBox[{"axis", ":", 
      RowBox[{"integer", " ", "labels"}]}]}], "*)"}], 
   RowBox[{
    RowBox[{
     RowBox[{"makeTicksX", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"vmin_", "?", "NumericQ"}], ",", 
        RowBox[{"vmax_", "?", "NumericQ"}]}], "}"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"maj", ",", "min"}], "}"}], ",", 
       RowBox[{
        RowBox[{"maj", "=", 
         RowBox[{"N", "@", 
          RowBox[{"FindDivisions", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"vmin", ",", "vmax"}], "}"}], ",", "6"}], "]"}]}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"min", "=", 
         RowBox[{"N", "@", 
          RowBox[{"Flatten", "@", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"Most", "@", 
              RowBox[{"Rest", "@", 
               RowBox[{"Subdivide", "[", 
                RowBox[{
                 RowBox[{"maj", "[", 
                  RowBox[{"[", "k", "]"}], "]"}], ",", 
                 RowBox[{"maj", "[", 
                  RowBox[{"[", 
                   RowBox[{"k", "+", "1"}], "]"}], "]"}], ",", "6"}], 
                "]"}]}]}], ",", 
             RowBox[{"{", 
              RowBox[{"k", ",", "1", ",", 
               RowBox[{
                RowBox[{"Length", "[", "maj", "]"}], "-", "1"}]}], "}"}]}], 
            "]"}]}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"#", ",", 
               RowBox[{"NumberForm", "[", 
                RowBox[{
                 RowBox[{"Round", "[", "#", "]"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"Infinity", ",", "0"}], "}"}]}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"majorLen", ",", "0"}], "}"}]}], "}"}], "&"}], "/@", 
            "maj"}], ")"}], ",", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"#", ",", "\"\<\>\"", ",", 
               RowBox[{"{", 
                RowBox[{"minorLen", ",", "0"}], "}"}]}], "}"}], "&"}], "/@", 
            "min"}], ")"}]}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Y", " ", 
