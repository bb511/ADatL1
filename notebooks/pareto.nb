   RowBox[{
    RowBox[{
     RowBox[{"toNum", "[", "s_String", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"t", "=", 
         RowBox[{"StringTrim", "[", "s", "]"}]}], "}"}], ",", 
       RowBox[{"Which", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"t", "==", "\"\<\>\""}], "||", 
          RowBox[{
           RowBox[{"ToLowerCase", "[", "t", "]"}], "==", "\"\<nan\>\""}], "||", 
          RowBox[{
           RowBox[{"ToLowerCase", "[", "t", "]"}], "==", "\"\<none\>\""}], "||", 
          RowBox[{
           RowBox[{"ToLowerCase", "[", "t", "]"}], "==", "\"\<null\>\""}]}], 
