Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "loadParetoData", "]"}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Loads", " ", "data", " ", "from", " ", "specified", " ", 
     RowBox[{"path", ".", " ", "Needs"}], " ", "to", " ", 
     RowBox[{"be", " ", ".", "csv"}], " ", "files"}], ",", " ", 
    RowBox[{"produced", " ", "with", " ", "fetch_optuna", 
     RowBox[{"_pareto", ".", "py"}], " ", "from", " ", "the", " ", 
     RowBox[{"optuna", " ", ".", "db"}], " ", 
     RowBox[{"file", "."}]}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"loadParetoData", "[", 
   RowBox[{"dataName_", ",", 
    RowBox[{"dir_", ":", "\"\<paretos\>\""}]}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "data", ",", "headers", ",", "rows", ",", "col", ",", "toNum", ",", 
      "toBool", ",", "isFiniteReal", ",", "completeRows", ",", "trialNumsRaw",
       ",", "trialNums", ",", "rawPts", ",", "ptsAll", ",", "paretoRaw", ",", 
      "paretoMask", ",", "goodMask", ",", "pts", ",", "paretoPts", ",", 
      "dominatedPts"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"data", "=", 
      RowBox[{"Import", "[", 
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{"dir", ",", 
          RowBox[{"dataName", "<>", "\"\<.csv\>\""}]}], "}"}], "]"}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"headers", "=", 
      RowBox[{"First", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rows", "=", 
      RowBox[{"Rest", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"col", "[", "name_", "]"}], ":=", 
      RowBox[{"First", "@", 
       RowBox[{"FirstPosition", "[", 
        RowBox[{"headers", ",", "name"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"toNum", "[", 
       RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
      RowBox[{"N", "@", "x"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"toNum", "[", "s_String", "]"}], ":=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"t", "=", 
          RowBox[{"ToLowerCase", "@", 
           RowBox[{"StringTrim", "[", "s", "]"}]}]}], "}"}], ",", 
        RowBox[{"Which", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"t", "==", "\"\<\>\""}], "||", 
           RowBox[{"t", "==", "\"\<nan\>\""}], "||", 
           RowBox[{"t", "==", "\"\<none\>\""}], "||", 
           RowBox[{"t", "==", "\"\<null\>\""}]}], ",", 
          RowBox[{"Missing", "[", "\"\<NotANumber\>\"", "]"}], ",", 
          RowBox[{
           RowBox[{"t", "==", "\"\<inf\>\""}], "||", 
           RowBox[{"t", "==", "\"\<+inf\>\""}], "||", 
           RowBox[{"t", "==", "\"\<infinity\>\""}]}], ",", "Infinity", ",", 
          RowBox[{
           RowBox[{"t", "==", "\"\<-inf\>\""}], "||", 
           RowBox[{"t", "==", "\"\<-infinity\>\""}]}], ",", 
          RowBox[{"-", "Infinity"}], ",", "True", ",", 
          RowBox[{"Quiet", "@", 
           RowBox[{"Check", "[", 
            RowBox[{
             RowBox[{"N", "@", 
              RowBox[{"ToExpression", "[", 
               RowBox[{"StringTrim", "[", "s", "]"}], "]"}]}], ",", 
             RowBox[{"Missing", "[", "\"\<NotANumber\>\"", "]"}]}], "]"}]}]}],
          "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"toNum", "[", "_", "]"}], ":=", 
      RowBox[{"Missing", "[", "\"\<NotANumber\>\"", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"toBool", "[", 
       RowBox[{"x_", "?", "BooleanQ"}], "]"}], ":=", "x"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"toBool", "[", "s_String", "]"}], ":=", 
      RowBox[{
       RowBox[{"ToLowerCase", "[", 
        RowBox[{"StringTrim", "[", "s", "]"}], "]"}], "===", 
       "\"\<true\>\""}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"toBool", "[", "_", "]"}], ":=", "False"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"isFiniteReal", "[", "x_", "]"}], ":=", 
      RowBox[{
       RowBox[{"NumericQ", "[", "x", "]"}], "&&", 
       RowBox[{"x", "=!=", "Indeterminate"}], "&&", 
       RowBox[{"x", "=!=", "ComplexInfinity"}], "&&", 
       RowBox[{"x", "=!=", "Infinity"}], "&&", 
       RowBox[{"x", "=!=", 
        RowBox[{"-", "Infinity"}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"completeRows", "=", 
      RowBox[{"Select", "[", 
       RowBox[{"rows", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", 
            RowBox[{"col", "[", "\"\<state\>\"", "]"}], "]"}], "]"}], "==", 
          "\"\<COMPLETE\>\""}], "&"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"trialNumsRaw", "=", 
      RowBox[{"completeRows", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"col", "[", "\"\<number\>\"", "]"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"trialNums", "=", 
      RowBox[{"trialNumsRaw", "/.", " ", 
       RowBox[{"s_String", ":>", 
        RowBox[{"Quiet", "@", 
         RowBox[{"Check", "[", 
          RowBox[{
           RowBox[{"ToExpression", "[", 
            RowBox[{"StringTrim", "[", "s", "]"}], "]"}], ",", "s"}], 
          "]"}]}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rawPts", "=", 
      RowBox[{"completeRows", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"col", "[", "\"\<values_0\>\"", "]"}], ",", 
           RowBox[{"col", "[", "\"\<values_1\>\"", "]"}]}], "}"}]}], "]"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ptsAll", "=", 
      RowBox[{"Map", "[", 
       RowBox[{"toNum", ",", "rawPts", ",", 
        RowBox[{"{", "2", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"paretoRaw", "=", 
      RowBox[{"completeRows", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"col", "[", "\"\<is_pareto\>\"", "]"}]}], "]"}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"paretoMask", "=", 
      RowBox[{"toBool", "/@", "paretoRaw"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"goodMask", "=", 
      RowBox[{"MapThread", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"MatchQ", "[", 
           RowBox[{"#1", ",", 
            RowBox[{"_Integer", "|", "_Real"}]}], "]"}], "&&", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"#2", ",", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"a_", ",", "b_"}], "}"}], "/;", 
             RowBox[{
              RowBox[{"isFiniteReal", "[", "a", "]"}], "&&", 
              RowBox[{"isFiniteReal", "[", "b", "]"}]}]}]}], "]"}]}], "&"}], 
        ",", 
        RowBox[{"{", 
         RowBox[{"trialNums", ",", "ptsAll"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"trialNums", "=", 
      RowBox[{"Pick", "[", 
       RowBox[{"trialNums", ",", "goodMask"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"pts", "=", 
      RowBox[{"Pick", "[", 
       RowBox[{"ptsAll", ",", "goodMask"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"paretoMask", "=", 
      RowBox[{"Pick", "[", 
       RowBox[{"paretoMask", ",", "goodMask"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"paretoPts", "=", 
      RowBox[{"Pick", "[", 
       RowBox[{"pts", ",", "paretoMask", ",", "True"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dominatedPts", "=", 
      RowBox[{"Pick", "[", 
       RowBox[{"pts", ",", "paretoMask", ",", "False"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<trialNums\>\"", "->", "trialNums"}], ",", 
       RowBox[{"\"\<pts\>\"", "->", "pts"}], ",", 
       RowBox[{"\"\<paretoMask\>\"", "->", "paretoMask"}], ",", 
       RowBox[{"\"\<paretoPts\>\"", "->", "paretoPts"}], ",", 
       RowBox[{"\"\<dominatedPts\>\"", "->", "dominatedPts"}], ",", 
       RowBox[{"\"\<paretoTrialNums\>\"", "->", 
        RowBox[{"Pick", "[", 
         RowBox[{"trialNums", ",", "paretoMask", ",", "True"}], "]"}]}], ",", 
       
       RowBox[{"\"\<dominatedTrialNums\>\"", "->", 
        RowBox[{"Pick", "[", 
         RowBox[{"trialNums", ",", "paretoMask", ",", "False"}], "]"}]}]}], 
      "|>"}]}]}], "\[IndentingNewLine]", "]"}]}]}], "Input",
 CellChangeTimes->{{3.9827418243900642`*^9, 3.9827418248172827`*^9}, 
   3.982741918365362*^9, 3.982750128227004*^9, {3.9830828046878433`*^9, 
   3.983082887548966*^9}},
 CellLabel->"In[38]:=",ExpressionUUID->"e46300d3-75c9-4a12-9b4d-d5fee579fed3"],

Cell["Pareto Plot: Inset Version", "Subtitle",
 CellChangeTimes->{{3.982742247421247*^9, 3.982742250013277*^9}, {
  3.9830829046439257`*^9, 
  3.983082913199503*^9}},ExpressionUUID->"f35ce9b4-0d70-4d24-b6f5-\
58399deb86ac"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "makeParetoPlot", "]"}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Helper", " ", "method", " ", "to", " ", "pad", " ", "the", " ", "range", 
    " ", "of", " ", "the", " ", 
    RowBox[{"plot", "."}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"padRange", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"xmin_", ",", "xmax_"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"ymin_", ",", "ymax_"}], "}"}]}], "}"}], ",", 
     RowBox[{"frac_", ":", "0.05"}]}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"dx", ",", "dy"}], "}"}], ",", 
     RowBox[{
      RowBox[{"dx", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"xmax", "-", "xmin"}], ")"}], "*", "frac"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"dy", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"ymax", "-", "ymin"}], ")"}], "*", "frac"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"xmin", "-", "dx"}], ",", 
          RowBox[{"xmax", "+", "dx"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"ymin", "-", "dy"}], ",", 
          RowBox[{"ymax", "+", "dy"}]}], "}"}]}], "}"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Pareto", " ", "plot", " ", "method", " ", "that", " ", "takes", " ", 
    "the", " ", "data", " ", "produced", " ", "with", " ", "the", " ", 
    "above", " ", "method", " ", "and", " ", "makes", " ", "the", " ", 
    RowBox[{"plot", "."}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"makeParetoPlot", "[", 
   RowBox[{
   "data_Association", ",", "xLabel_", ",", "yLabel_", ",", " ", "zoomRange_",
     ",", "zoomedPlotPos_", ",", "zoomedPlotSize_", ",", "rangePadding_", ",",
     "legendPos_", ",", "cmsPos_", ",", "tevPos_", ",", " ", 
    RowBox[{"precX_", ":", " ", "2"}], ",", " ", 
    RowBox[{"precY_", ":", " ", "2"}], ",", " ", 
    RowBox[{"showZoom_", ":", "True"}], ",", 
    RowBox[{"showZoomBox_", ":", "True"}], ",", " ", 
    RowBox[{"logLog_", ":", "False"}], ",", " ", 
    RowBox[{"invertLines_", ":", " ", "False"}], ",", " ", 
    RowBox[{"highlightTrials_", ":", 
     RowBox[{"{", "}"}]}]}], "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "pts", ",", "paretoPts", ",", "dominatedPts", ",", "xVals", ",", "yVals",
       ",", "majorLen", ",", "minorLen", ",", "makeTicks01", ",", 
      "makeLogTicks", ",", "xTicks", ",", "yTicks", ",", "frameTicksSpec", 
      ",", "plt", ",", "zoomPlt", ",", "zoomPad", ",", "zoomImageSize", ",", 
      "paddedZoom", ",", "leftFrac", ",", "rightFrac", ",", "bottomFrac", ",",
       "topFrac", ",", "insetBL", ",", "insetTR", ",", "insetTL", ",", 
      "insetBR", ",", "cmsText", ",", "tevText", ",", "outer", ",", 
      "mainPlotFn", ",", "effectiveShowZoom", ",", "effectiveShowZoomBox", 
      ",", " ", "legend", ",", " ", "epilogParts"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"pts", "=", 
      RowBox[{"data", "[", "\"\<pts\>\"", "]"}]}], ";", "\[IndentingNewLine]",
      "\[IndentingNewLine]", 
     RowBox[{"paretoAssoc", "=", 
      RowBox[{"AssociationThread", "[", 
       RowBox[{
        RowBox[{"data", "[", "\"\<paretoTrialNums\>\"", "]"}], "->", 
        RowBox[{"data", "[", "\"\<paretoPts\>\"", "]"}]}], "]"}]}], ";", "\n", 
     RowBox[{"dominatedAssoc", "=", 
      RowBox[{"AssociationThread", "[", 
       RowBox[{
        RowBox[{"data", "[", "\"\<dominatedTrialNums\>\"", "]"}], "->", 
        RowBox[{"data", "[", "\"\<dominatedPts\>\"", "]"}]}], "]"}]}], ";", 
     "\n", 
     RowBox[{"trialToPoint", "=", 
      RowBox[{"Join", "[", 
       RowBox[{"paretoAssoc", ",", "dominatedAssoc"}], "]"}]}], ";", "\n", 
     RowBox[{"markedPts", "=", 
      RowBox[{"Lookup", "[", 
       RowBox[{"trialToPoint", ",", "highlightTrials", ",", 
        RowBox[{"{", "}"}]}], "]"}]}], ";", 
     RowBox[{"paretoPts", "=", 
      RowBox[{"data", "[", "\"\<paretoPts\>\"", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dominatedPts", "=", 
      RowBox[{"data", "[", "\"\<dominatedPts\>\"", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"xVals", "=", 
      RowBox[{"pts", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"yVals", "=", 
      RowBox[{"pts", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"majorLen", "=", 
      RowBox[{"Scaled", "[", "0.015", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"minorLen", "=", 
      RowBox[{"Scaled", "[", 
       RowBox[{"0.015", "/", "2"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"effectiveShowZoom", "=", 
      RowBox[{"showZoom", "&&", 
       RowBox[{"!", "logLog"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"effectiveShowZoomBox", "=", 
      RowBox[{"showZoomBox", "&&", 
       RowBox[{"!", "logLog"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"makeTicks01", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"vmin_", "?", "NumericQ"}], ",", 
          RowBox[{"vmax_", "?", "NumericQ"}]}], "}"}], ",", "prec_"}], "]"}], 
      ":=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"maj", ",", "min"}], "}"}], ",", 
        RowBox[{
         RowBox[{"maj", "=", 
          RowBox[{"N", "@", 
           RowBox[{"FindDivisions", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"vmin", ",", "vmax"}], "}"}], ",", "6"}], "]"}]}]}], 
         ";", "\[IndentingNewLine]", 
         RowBox[{"min", "=", 
          RowBox[{"N", "@", 
           RowBox[{"Flatten", "@", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"Most", "@", 
               RowBox[{"Rest", "@", 
                RowBox[{"Subdivide", "[", 
                 RowBox[{
                  RowBox[{"maj", "[", 
                   RowBox[{"[", "k", "]"}], "]"}], ",", 
                  RowBox[{"maj", "[", 
                   RowBox[{"[", 
                    RowBox[{"k", "+", "1"}], "]"}], "]"}], ",", "6"}], 
                 "]"}]}]}], ",", 
              RowBox[{"{", 
               RowBox[{"k", ",", "1", ",", 
                RowBox[{
                 RowBox[{"Length", "[", "maj", "]"}], "-", "1"}]}], "}"}]}], 
             "]"}]}]}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"#", ",", 
                RowBox[{"NumberForm", "[", 
                 RowBox[{"#", ",", 
                  RowBox[{"{", 
                   RowBox[{"Infinity", ",", "prec"}], "}"}]}], "]"}], ",", 
                RowBox[{"{", 
                 RowBox[{"majorLen", ",", "0"}], "}"}]}], "}"}], "&"}], "/@", 
             "maj"}], ")"}], ",", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"#", ",", "\"\<\>\"", ",", 
                RowBox[{"{", 
                 RowBox[{"minorLen", ",", "0"}], "}"}]}], "}"}], "&"}], "/@", 
             "min"}], ")"}]}], "]"}]}]}], "]"}]}], ";", "\[IndentingNewLine]",
      "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"makeLogTicks", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"vmin_", "?", "NumericQ"}], ",", 
         RowBox[{"vmax_", "?", "NumericQ"}]}], "}"}], "]"}], ":=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"emin", ",", "emax", ",", "majors", ",", "minors"}], "}"}], 
        ",", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"vmin", "<=", "0"}], "||", 
            RowBox[{"vmax", "<=", "0"}]}], ",", 
           RowBox[{"Return", "[", 
            RowBox[{"{", "}"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"emin", "=", 
          RowBox[{"Floor", "[", 
           RowBox[{"Log10", "[", "vmin", "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"emax", "=", 
          RowBox[{"Ceiling", "[", 
           RowBox[{"Log10", "[", "vmax", "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"majors", "=", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"10.", "^", "e"}], ",", 
            RowBox[{"{", 
             RowBox[{"e", ",", "emin", ",", "emax"}], "}"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"minors", "=", 
          RowBox[{"Flatten", "@", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"m", "*", 
                RowBox[{"10.", "^", "e"}]}], ",", 
               RowBox[{"{", 
                RowBox[{"m", ",", "2", ",", "9"}], "}"}]}], "]"}], ",", 
