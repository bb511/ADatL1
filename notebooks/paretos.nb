Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "loadParetoData", "]"}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"loadParetoData", "[", 
   RowBox[{"dataName_", ",", 
    RowBox[{"dir_", ":", "\"\<paretos\>\""}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "data", ",", "headers", ",", "rows", ",", "col", ",", "toNum", ",", 
      "toBool", ",", "isFiniteReal", ",", "completeRows", ",", "trialNumsRaw",
       ",", "trialNums", ",", "rawPts", ",", "ptsAll", ",", "paretoRaw", ",", 
      "paretoMask", ",", "goodMask", ",", "pts", ",", "paretoPts", ",", 
      "dominatedPts"}], "}"}], ",", 
    RowBox[{
     RowBox[{"data", "=", 
      RowBox[{"Import", "[", 
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{"dir", ",", 
          RowBox[{"dataName", "<>", "\"\<.csv\>\""}]}], "}"}], "]"}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"headers", "=", 
      RowBox[{"First", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rows", "=", 
      RowBox[{"Rest", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"col", "[", "name_", "]"}], ":=", 
      RowBox[{"First", "@", 
       RowBox[{"FirstPosition", "[", 
        RowBox[{"headers", ",", "name"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"toNum", "[", 
       RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
      RowBox[{"N", "@", "x"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"toNum", "[", "s_String", "]"}], ":=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"t", "=", 
          RowBox[{"ToLowerCase", "@", 
           RowBox[{"StringTrim", "[", "s", "]"}]}]}], "}"}], ",", 
        RowBox[{"Which", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"t", "==", "\"\<\>\""}], "||", 
           RowBox[{"t", "==", "\"\<nan\>\""}], "||", 
           RowBox[{"t", "==", "\"\<none\>\""}], "||", 
           RowBox[{"t", "==", "\"\<null\>\""}]}], ",", 
          RowBox[{"Missing", "[", "\"\<NotANumber\>\"", "]"}], ",", 
          RowBox[{
           RowBox[{"t", "==", "\"\<inf\>\""}], "||", 
           RowBox[{"t", "==", "\"\<+inf\>\""}], "||", 
           RowBox[{"t", "==", "\"\<infinity\>\""}]}], ",", "Infinity", ",", 
          RowBox[{
           RowBox[{"t", "==", "\"\<-inf\>\""}], "||", 
           RowBox[{"t", "==", "\"\<-infinity\>\""}]}], ",", 
          RowBox[{"-", "Infinity"}], ",", "True", ",", 
          RowBox[{"Quiet", "@", 
           RowBox[{"Check", "[", 
            RowBox[{
             RowBox[{"N", "@", 
              RowBox[{"ToExpression", "[", 
               RowBox[{"StringTrim", "[", "s", "]"}], "]"}]}], ",", 
             RowBox[{"Missing", "[", "\"\<NotANumber\>\"", "]"}]}], "]"}]}]}],
          "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"toNum", "[", "_", "]"}], ":=", 
      RowBox[{"Missing", "[", "\"\<NotANumber\>\"", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"toBool", "[", 
       RowBox[{"x_", "?", "BooleanQ"}], "]"}], ":=", "x"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"toBool", "[", "s_String", "]"}], ":=", 
      RowBox[{
       RowBox[{"ToLowerCase", "[", 
        RowBox[{"StringTrim", "[", "s", "]"}], "]"}], "===", 
       "\"\<true\>\""}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"toBool", "[", "_", "]"}], ":=", "False"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"isFiniteReal", "[", "x_", "]"}], ":=", 
      RowBox[{
       RowBox[{"NumericQ", "[", "x", "]"}], "&&", 
       RowBox[{"x", "=!=", "Indeterminate"}], "&&", 
       RowBox[{"x", "=!=", "ComplexInfinity"}], "&&", 
       RowBox[{"x", "=!=", "Infinity"}], "&&", 
       RowBox[{"x", "=!=", 
        RowBox[{"-", "Infinity"}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"completeRows", "=", 
      RowBox[{"Select", "[", 
       RowBox[{"rows", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", 
            RowBox[{"col", "[", "\"\<state\>\"", "]"}], "]"}], "]"}], "==", 
          "\"\<COMPLETE\>\""}], "&"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"trialNumsRaw", "=", 
      RowBox[{"completeRows", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"col", "[", "\"\<number\>\"", "]"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"trialNums", "=", 
      RowBox[{"trialNumsRaw", "/.", " ", 
       RowBox[{"s_String", ":>", 
        RowBox[{"Quiet", "@", 
         RowBox[{"Check", "[", 
          RowBox[{
           RowBox[{"ToExpression", "[", 
            RowBox[{"StringTrim", "[", "s", "]"}], "]"}], ",", "s"}], 
          "]"}]}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rawPts", "=", 
      RowBox[{"completeRows", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"col", "[", "\"\<values_0\>\"", "]"}], ",", 
           RowBox[{"col", "[", "\"\<values_1\>\"", "]"}]}], "}"}]}], "]"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ptsAll", "=", 
      RowBox[{"Map", "[", 
       RowBox[{"toNum", ",", "rawPts", ",", 
        RowBox[{"{", "2", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"paretoRaw", "=", 
      RowBox[{"completeRows", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"col", "[", "\"\<is_pareto\>\"", "]"}]}], "]"}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"paretoMask", "=", 
      RowBox[{"toBool", "/@", "paretoRaw"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"goodMask", "=", 
      RowBox[{"MapThread", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"MatchQ", "[", 
           RowBox[{"#1", ",", 
            RowBox[{"_Integer", "|", "_Real"}]}], "]"}], "&&", 
          RowBox[{"MatchQ", "[", 
           RowBox[{"#2", ",", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"a_", ",", "b_"}], "}"}], "/;", 
             RowBox[{
              RowBox[{"isFiniteReal", "[", "a", "]"}], "&&", 
              RowBox[{"isFiniteReal", "[", "b", "]"}]}]}]}], "]"}]}], "&"}], 
        ",", 
        RowBox[{"{", 
         RowBox[{"trialNums", ",", "ptsAll"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"trialNums", "=", 
      RowBox[{"Pick", "[", 
       RowBox[{"trialNums", ",", "goodMask"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"pts", "=", 
      RowBox[{"Pick", "[", 
       RowBox[{"ptsAll", ",", "goodMask"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"paretoMask", "=", 
      RowBox[{"Pick", "[", 
       RowBox[{"paretoMask", ",", "goodMask"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"paretoPts", "=", 
      RowBox[{"Pick", "[", 
       RowBox[{"pts", ",", "paretoMask", ",", "True"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dominatedPts", "=", 
      RowBox[{"Pick", "[", 
       RowBox[{"pts", ",", "paretoMask", ",", "False"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<trialNums\>\"", "->", "trialNums"}], ",", 
       RowBox[{"\"\<pts\>\"", "->", "pts"}], ",", 
       RowBox[{"\"\<paretoMask\>\"", "->", "paretoMask"}], ",", 
       RowBox[{"\"\<paretoPts\>\"", "->", "paretoPts"}], ",", 
       RowBox[{"\"\<dominatedPts\>\"", "->", "dominatedPts"}], ",", 
       RowBox[{"\"\<paretoTrialNums\>\"", "->", 
        RowBox[{"Pick", "[", 
         RowBox[{"trialNums", ",", "paretoMask", ",", "True"}], "]"}]}], ",", 
       
       RowBox[{"\"\<dominatedTrialNums\>\"", "->", 
        RowBox[{"Pick", "[", 
         RowBox[{"trialNums", ",", "paretoMask", ",", "False"}], "]"}]}]}], 
      "|>"}]}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9827418243900642`*^9, 3.9827418248172827`*^9}, 
   3.982741918365362*^9, 3.982750128227004*^9},
 CellLabel->"In[18]:=",ExpressionUUID->"e46300d3-75c9-4a12-9b4d-d5fee579fed3"],

Cell["Pareto Plot Method", "Subtitle",
 CellChangeTimes->{{3.982742247421247*^9, 
  3.982742250013277*^9}},ExpressionUUID->"f35ce9b4-0d70-4d24-b6f5-\
58399deb86ac"],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "makeParetoPlot", "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"padRange", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"xmin_", ",", "xmax_"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"ymin_", ",", "ymax_"}], "}"}]}], "}"}], ",", 
      RowBox[{"frac_", ":", "0.05"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"dx", ",", "dy"}], "}"}], ",", 
      RowBox[{
       RowBox[{"dx", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"xmax", "-", "xmin"}], ")"}], "*", "frac"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"dy", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"ymax", "-", "ymin"}], ")"}], "*", "frac"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"xmin", "-", "dx"}], ",", 
           RowBox[{"xmax", "+", "dx"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"ymin", "-", "dy"}], ",", 
           RowBox[{"ymax", "+", "dy"}]}], "}"}]}], "}"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"makeParetoPlot", "[", 
     RowBox[{
     "data_Association", ",", "xLabel_", ",", "yLabel_", ",", " ", 
      "zoomRange_", ",", "zoomedPlotPos_", ",", "zoomedPlotSize_", ",", 
      "rangePadding_", ",", " ", 
      RowBox[{"showZoom_", ":", "True"}], ",", 
      RowBox[{"showZoomBox_", ":", "True"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "pts", ",", "paretoPts", ",", "dominatedPts", ",", "xVals", ",", 
        "yVals", ",", "majorLen", ",", "minorLen", ",", "makeTicks01", ",", 
        "xTicks", ",", "yTicks", ",", "frameTicksSpec", ",", "plt", ",", 
        "zoomPlt", ",", "zoomPad", ",", " ", "zoomImageSize", ",", 
        "paddedZoom", ",", " ", "cmsText", ",", "tevText", ",", "outer"}], 
       "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"pts", "=", 
        RowBox[{"data", "[", "\"\<pts\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"paretoPts", "=", 
        RowBox[{"data", "[", "\"\<paretoPts\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"dominatedPts", "=", 
        RowBox[{"data", "[", "\"\<dominatedPts\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"xVals", "=", 
        RowBox[{"pts", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yVals", "=", 
        RowBox[{"pts", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"majorLen", "=", 
        RowBox[{"Scaled", "[", "0.015", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"minorLen", "=", 
        RowBox[{"Scaled", "[", 
         RowBox[{"0.015", "/", "2"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"makeTicks01", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"vmin_", "?", "NumericQ"}], ",", 
           RowBox[{"vmax_", "?", "NumericQ"}]}], "}"}], "]"}], ":=", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"maj", ",", "min"}], "}"}], ",", 
          RowBox[{
           RowBox[{"maj", "=", 
            RowBox[{"N", "@", 
             RowBox[{"FindDivisions", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"vmin", ",", "vmax"}], "}"}], ",", "6"}], "]"}]}]}], 
           ";", "\[IndentingNewLine]", 
           RowBox[{"min", "=", 
            RowBox[{"N", "@", 
             RowBox[{"Flatten", "@", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"Most", "@", 
                 RowBox[{"Rest", "@", 
                  RowBox[{"Subdivide", "[", 
                   RowBox[{
                    RowBox[{"maj", "[", 
                    RowBox[{"[", "k", "]"}], "]"}], ",", 
                    RowBox[{"maj", "[", 
                    RowBox[{"[", 
                    RowBox[{"k", "+", "1"}], "]"}], "]"}], ",", "6"}], 
                   "]"}]}]}], ",", 
                RowBox[{"{", 
                 RowBox[{"k", ",", "1", ",", 
                  RowBox[{
                   RowBox[{"Length", "[", "maj", "]"}], "-", "1"}]}], "}"}]}],
                "]"}]}]}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"Join", "[", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"#", ",", 
                  RowBox[{"NumberForm", "[", 
                   RowBox[{"#", ",", 
                    RowBox[{"{", 
                    RowBox[{"Infinity", ",", "2"}], "}"}]}], "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"majorLen", ",", "0"}], "}"}]}], "}"}], "&"}], "/@",
                "maj"}], ")"}], ",", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"#", ",", "\"\<\>\"", ",", 
                  RowBox[{"{", 
                   RowBox[{"minorLen", ",", "0"}], "}"}]}], "}"}], "&"}], "/@",
                "min"}], ")"}]}], "]"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"xTicks", "=", 
        RowBox[{"makeTicks01", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Min", "[", "xVals", "]"}], ",", 
           RowBox[{"Max", "[", "xVals", "]"}]}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yTicks", "=", 
        RowBox[{"makeTicks01", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Min", "[", "yVals", "]"}], ",", 
           RowBox[{"Max", "[", "yVals", "]"}]}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"frameTicksSpec", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"yTicks", ",", 
            RowBox[{"(", 
             RowBox[{"yTicks", "/.", " ", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"v_", ",", "lab_", ",", "len_"}], "}"}], ":>", 
               RowBox[{"{", 
                RowBox[{"v", ",", "\"\<\>\"", ",", "len"}], "}"}]}]}], 
             ")"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"xTicks", ",", 
            RowBox[{"(", 
             RowBox[{"xTicks", "/.", " ", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"v_", ",", "lab_", ",", "len_"}], "}"}], ":>", 
               RowBox[{"{", 
                RowBox[{"v", ",", "\"\<\>\"", ",", "len"}], "}"}]}]}], 
             ")"}]}], "}"}]}], "}"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"paddedZoom", "=", 
        RowBox[{"padRange", "[", 
         RowBox[{"zoomRange", ",", "0.1"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"zoomPad", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"55", ",", "12"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"35", ",", "12"}], "}"}]}], "}"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"zoomImageSize", "=", 
        RowBox[{"{", 
         RowBox[{"500", ",", "320"}], "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"zoomPlt", "=", 
        RowBox[{"Show", "[", 
         RowBox[{
          RowBox[{"ListPlot", "[", 
           RowBox[{"dominatedPts", ",", 
            RowBox[{"PlotStyle", "->", 
             RowBox[{"Directive", "[", 
              RowBox[{
               RowBox[{"RGBColor", "[", "\"\<#3f90da\>\"", "]"}], ",", 
               RowBox[{"AbsolutePointSize", "[", "6", "]"}]}], "]"}]}]}], 
           "]"}], ",", 
          RowBox[{"ListPlot", "[", 
           RowBox[{"paretoPts", ",", 
            RowBox[{"PlotStyle", "->", 
             RowBox[{"Directive", "[", 
              RowBox[{
               RowBox[{"RGBColor", "[", "\"\<#bd1f01\>\"", "]"}], ",", 
               RowBox[{"AbsolutePointSize", "[", "6", "]"}]}], "]"}]}]}], 
           "]"}], ",", 
          RowBox[{"Axes", "->", "False"}], ",", 
          RowBox[{"Frame", "->", "True"}], ",", 
          RowBox[{"PlotRange", "->", "zoomRange"}], ",", " ", 
          RowBox[{"PlotRangePadding", "->", "None"}], ",", 
          RowBox[{"ImagePadding", "->", "zoomPad"}], ",", 
          RowBox[{"FrameTicksStyle", "->", 
           RowBox[{"Directive", "[", 
            RowBox[{"Black", ",", 
             RowBox[{"FontSize", "->", "14"}]}], "]"}]}], ",", 
          RowBox[{"PlotRangeClipping", "->", "True"}], ",", " ", 
          RowBox[{"ImageSize", "->", "zoomImageSize"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"leftFrac", "=", 
        RowBox[{
         RowBox[{"zoomPad", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}], "/", 
         RowBox[{"zoomImageSize", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\n", "    ", 
       RowBox[{"rightFrac", "=", 
        RowBox[{
         RowBox[{"zoomPad", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "2"}], "]"}], "]"}], "/", 
         RowBox[{"zoomImageSize", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\n", "    ", 
       RowBox[{"bottomFrac", "=", 
        RowBox[{
         RowBox[{"zoomPad", "[", 
          RowBox[{"[", 
           RowBox[{"2", ",", "1"}], "]"}], "]"}], "/", 
         RowBox[{"zoomImageSize", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}]}], ";", "\n", "    ", 
       RowBox[{"topFrac", "=", 
        RowBox[{
         RowBox[{"zoomPad", "[", 
          RowBox[{"[", 
           RowBox[{"2", ",", "2"}], "]"}], "]"}], "/", 
         RowBox[{"zoomImageSize", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}]}], ";", "\n", "    ", 
       RowBox[{"insetBL", "=", 
        RowBox[{"zoomedPlotPos", "+", 
         RowBox[{"zoomedPlotSize", "*", 
          RowBox[{"{", 
           RowBox[{"leftFrac", ",", "bottomFrac"}], "}"}]}]}]}], ";", "\n", 
       "    ", 
       RowBox[{"insetTR", "=", 
        RowBox[{"zoomedPlotPos", "+", 
         RowBox[{"zoomedPlotSize", "*", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"1", "-", "rightFrac"}], ",", 
            RowBox[{"1", "-", "topFrac"}]}], "}"}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"insetTL", "=", 
        RowBox[{"{", 
         RowBox[{
